# Temporal server connection
TEMPORAL_HOST=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=ztp-queue

# Nautobot connection
NAUTOBOT_URL=http://localhost:8080
NAUTOBOT_TOKEN=your-nautobot-api-token-here

# Prometheus metrics (optional — leave blank to disable)
METRICS_PORT=9091

# Logging
LOG_LEVEL=INFO
